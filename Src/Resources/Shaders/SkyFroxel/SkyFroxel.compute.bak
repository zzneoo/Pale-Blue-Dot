#version 460 core

const float PI = 3.14159265359;
const float kLengthUnitInMeters = 100.0;
const float AtmoTopRadius = 66200.0;

layout(local_size_x = 8, local_size_y = 8, local_size_z = 8) in;

uniform layout(rgba16f, binding = 0) writeonly image3D TransmittanceImage;
uniform layout(rgba16f, binding = 1) writeonly image3D InScatterImage;

uniform float fArtistFactor;

uniform mat4 m4InvViewX;
uniform mat4 m4InvProjX;

uniform vec2 v2NearFar;

uniform vec3 v3SunPos;
uniform vec3 v3EyePos;
uniform vec3 v3EarthCenter;
uniform vec2 v2SunSize;


vec3 GetSkyRadianceToPoint(vec3 camera, vec3 point, float shadow_length,
    vec3 sun_direction, out vec3 transmittance);


void main(void)
{
	ivec3  Voxel = ivec3(gl_GlobalInvocationID.xyz);
	
	vec3 FroxelCoords = (Voxel + 0.5)/64.0;
	FroxelCoords.xy = FroxelCoords.xy * 2.0 - 1.0;
	
	vec4 ViewRay = m4InvProjX*vec4(FroxelCoords.xy,1.0,1.0);
	ViewRay.w = 0.0;
	
	vec3 WorldSpaceViewDir = normalize((m4InvViewX* ViewRay).xyz);
		
	vec3 FroxelWorldSpacePosition = (v3EyePos + WorldSpaceViewDir * v2NearFar.x) + WorldSpaceViewDir * v2NearFar.y * FroxelCoords.z;
		
	vec3 toSunDir = normalize(v3SunPos);
	
    vec3 transmittance;
    vec3 in_scatter = GetSkyRadianceToPoint(v3EyePos - v3EarthCenter, FroxelWorldSpacePosition.xyz - v3EarthCenter, 0.0, toSunDir, transmittance);

  imageStore(TransmittanceImage, Voxel, vec4(transmittance,1.0));
  imageStore(InScatterImage, Voxel, vec4(in_scatter,1.0));
}
