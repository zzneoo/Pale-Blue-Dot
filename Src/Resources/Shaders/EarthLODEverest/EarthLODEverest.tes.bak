#version 460 core

const float PI = 3.14159265359;

layout(quads, fractional_even_spacing, ccw) in;

uniform float fArtistFactor;

uniform mat4 m4ModelX;
uniform mat4 m4ViewProjX;
uniform mat4 m4PrevViewProjX;
uniform mat4 m4JitteredViewProjX;

uniform mat4 m4EarthRotX;//for UV rotation

out mat3 TangentToWorld;

//terrain (not material)
uniform sampler2D tSampler_Heightmap;

in vec2 tcsTexCoords[];

out vec4 lightSpaceFragPos;

out vec2 tesTexCoords;
smooth out vec4 CurrPos;
smooth out vec4 PrevPos;
out vec4 worldPos;
out float terrainHeight;

out float flogz;
out float depth;
uniform float FcoefForLog;

vec2 GetLOD_UV(float lodScale,vec2 baseUV,vec2 lodOffset,vec2 aspectCorrectionFactor) 
{
    vec2 aspectCorrectScale = vec2(lodScale*2*aspectCorrectionFactor.x,lodScale*aspectCorrectionFactor.y);
    vec2 finalScale = 64*aspectCorrectScale;
    vec2 offset = (aspectCorrectScale*0.5)+vec2(0.5)-aspectCorrectScale;
    
    return ((vec2(baseUV.s,baseUV.t)*finalScale)-(vec2(48.974530+lodOffset.x,41.22625+lodOffset.y)*aspectCorrectScale)+vec2(offset.x,offset.y));
}

void main(void)
{
    vec2 tc1 = mix(tcsTexCoords[0], tcsTexCoords[1], gl_TessCoord.x);
    vec2 tc2 = mix(tcsTexCoords[2], tcsTexCoords[3], gl_TessCoord.x);
    vec2 tc = mix(tc2, tc1, gl_TessCoord.y);

    tesTexCoords = tc;

    vec4 p1 = mix(gl_in[0].gl_Position, gl_in[1].gl_Position, gl_TessCoord.x);
    vec4 p2 = mix(gl_in[2].gl_Position, gl_in[3].gl_Position, gl_TessCoord.x);
    vec4 p = mix(p2, p1, gl_TessCoord.y);
		
	worldPos = m4ModelX * p;
	vec3 N =	normalize(worldPos.xyz +vec3(0.0,63600.0,0.0));
	worldPos.xyz =(N*63600.0)-vec3(0.0,63600.0,0.0);
	
	vec3 rotatedNormalForUV = mat3(m4EarthRotX)*N;
	vec2 rotatedUV;
	rotatedUV.x = 0.5 + atan(-rotatedNormalForUV.x,rotatedNormalForUV.z)/(2.0*PI);
    rotatedUV.y = 0.5 - asin(rotatedNormalForUV.y)/PI;
	
    vec2 EarthEverestLOD_UV =  GetLOD_UV(0.3900224,rotatedUV,vec2(-2.006145,-0.199),vec2(1.0,1.0));//
	tesTexCoords = EarthEverestLOD_UV;
	
	float height = texture(tSampler_Heightmap, vec2(EarthEverestLOD_UV)).r;//Raw16 y is inversed  here its .tga 
	worldPos.xyz+=((N*height*128));
	
	vec3 T = normalize( cross(  N ,vec3(0,1,0)) );  
    vec3 B = normalize(cross( T,N ));
		
	TangentToWorld = mat3(T,B,N);
	
	vec4 clipSpace = m4ViewProjX*worldPos;
	CurrPos = clipSpace;
	//vec4 NDC = clipSpace/clipSpace.w;
	//vec2 CurrUV = NDC.xy*0.5+0.5;
	
	vec4 prevClipSpace = m4PrevViewProjX*worldPos;
	PrevPos = prevClipSpace;
	//vec4 prevNDC =prevClipSpace/prevClipSpace.w; 
	//vec2 PrevUV = prevNDC.xy*0.5+0.5;
	

    gl_Position = m4JitteredViewProjX*worldPos;
	
	depth = gl_Position.z/gl_Position.w;
	
	//Logarithmic depth
	//float Fcoef = 1.0 / log2(2000000.0 + 1.0);
    flogz = 1.0 + gl_Position.w;	
	//gl_Position.z = log2(max(1e-6, flogz)) *FcoefForLog ;
	//gl_Position.z *= gl_Position.w;//do or not to do?
}
