float ZzCloudDensity(vec3 cloudPos, float HeightFract)
{
	vec2 WeatherUV = getUVProjection(cloudPos.xz, 16);
	vec2 WeatherUVHigh = getUVProjection(cloudPos.xz, 32 * 0.7);
	vec2 LowWeatherUV = getUVProjection(cloudPos.xz, 1);

	vec2 WeatherUVSpace = getUVProjection(cloudPos.xz, 4);
	vec2 CloudCoverage = texture(tSampler2D_WeatherMap, WeatherUV).rb;
	vec2 LowCloudCoverage = texture(tSampler2D_WeatherMap, WeatherUVSpace).rg;
	float HD = getDensityHeightGradientCloud(HeightFract, 1.0);
	float HD_variation = getDensityHeightGradientCloud(HeightFract, 0.4);

	vec4 noise = texture(tSampler3D_PerlinWorley, vec3(LowWeatherUV * 100.0, HeightFract * 0.147 * v2InnerOuterRadius.y));
	vec4 noiseHigh = texture(tSampler3D_PerlinWorley, (6.97 * vec3(LowWeatherUV * 100.0, HeightFract * 0.147 * v2InnerOuterRadius.y)));

	float baseWorleyFBM = dot(noise.rgb, vec3(0.725, 0.1875, 0.0875));
	float noiseHighFBM = dot(noiseHigh.rgb, vec3(0.625, 0.25, 0.125));
	float baseCloud = CloudCoverage.r * HD;

	baseCloud = Remap(baseCloud, (1.0 - baseWorleyFBM), 1.0, (0.0), 1.0);//basecloud shape
	baseCloud = Remap(baseCloud, (1.0 - noiseHighFBM) * 0.403, 1.0, (0.0), 1.0);//basecloud shape

//	float Density = mix(noise.a,baseCloud, smoothstep(0.2,0.3, HeightFract)) * pow(HeightFract, 0.9);//space
	float Density = baseCloud * pow(HeightFract, 0.9) * CloudCoverage.r;//space

	float TilablePerlin = texture(tSampler2D_WeatherMapTilable, WeatherUVHigh).b;

	//return Density * 0.15 + 0.4 * noise.a * pow(TilablePerlin, 2.0) * LowCloudCoverage.g * HD_variation;//+0.1* CloudCoverage.g* HD_variation

	return clamp(Density * 0.15 + 0.2 * noise.a * pow(TilablePerlin, 1.0) * LowCloudCoverage.g * HD_variation, 0.0, 1.0);
	//return Density * 0.15;
}

void main(void)
{
	//uint ID = (gl_LocalInvocationID.y % 4 * gl_WorkGroupSize.x/4 ) + gl_LocalInvocationID.x % 4;
	vec3 startPos, endPos;
	vec2 temporalUV;

	ivec2 fragCoords = ivec2(gl_GlobalInvocationID.xy);

	vec2 resolution = vec2(8192.0);

	vec2 pixelOffset;
	pixelOffset.x = iPixelID % 16;
	pixelOffset.y = iPixelID / 16;

	temporalUV = ((fragCoords * 16) + 0.5 + pixelOffset);

	//vec2 uvCoords = temporalUV / resolution;//reprojection
	vec2 uvCoords = (fragCoords+0.5) / resolution;//offline
	vec3 camPos = v3CameraPosition;

	//camPos = vec3(0.0, 10.0, 0.0);

	vec2 ndcRay = (2.0 * (uvCoords)-1.0);//-1 to 1
	//ndcRay.x *= 1920.0 / 1080.0;
	vec4 ray_view = m4InvProjX *  vec4(ndcRay, 1.0, 1.0);
	//ray_view = vec4(ray_view.x / -ray_view.z, ray_view.y / ray_view.z, -1.0, 0.0);
	ray_view = vec4(ray_view.xyz, 0.0);

	vec3 worldDir = (m4InvViewX * ray_view).xyz;
	worldDir = normalize(worldDir);

	ray_t ray = { camPos,worldDir,0.0 };

	float lengthOfCameraPos = length(camPos-sphereCenter);//relative to sphere origin

	bool hit = false;

	bool hitFirst, hitSecond;
	vec3 p1, p2, q1, q2;
	float tMinFirst, tMaxFirst, tMinSecond, tMaxSecond;
	float tMinFinal, tMaxFinal;

	hitFirst = IntersectSphereFromOutside(ray.origin, ray.direction, SPHERE_OUTER_RADIUS, p1, p2 , tMinFirst ,tMaxFirst);
	hitSecond = IntersectSphereFromOutside(ray.origin, ray.direction, SPHERE_INNER_RADIUS, q1, q2 , tMinSecond , tMaxSecond);


	if (hitFirst == false)
	{
		hit = false;

	}
	else
	{
		startPos = p1;
		endPos = p2;
		tMinFinal = tMinFirst;
		tMaxFinal = tMaxFirst;

		if (hitSecond == true)
		{
			endPos = q1;
			tMaxFinal = tMinSecond;
		}

		hit = true;
	}

	volume_sampler_t cloud = { startPos , startPos , 0.0, 1.0 , vec3(0), 0.0, startPos };
	

	bool firstPos = true;

	float FrontDepth = 300000;
	vec3 frontCloudPos = ray.origin+ ray.direction*300000 ;
	float MeanExtinction = 0.0;
	float MaxOpticalDepth = 0.0;
	float ExtinctionAccumulator = 0.0;

	//float weather = texture(tSampler2D_WeatherMap, getUVProjection(startPos.xz)*2.0).r;

	if (hit == true)
	{

		vec3 path = endPos - startPos;
		float len = length(path);
		float nSteps = cld_march_steps_max;
		float deltaStepLength = len / nSteps;
		vec3 deltaStep = path / nSteps;

		cloud.pos = startPos;
		float Depth = tMinFinal;
		
		float sampleCounter = 0;

		while (sampleCounter < nSteps )
		{

				cloud.height = clamp(getHeightFraction(cloud.pos), 0.0, 1.0);
				float baseDensity = ZzCloudDensity(cloud.pos, cloud.height);

				if (baseDensity > 0.01 )
				{


					if (firstPos == true)
					{
						frontCloudPos = cloud.pos;
						FrontDepth = Depth;
						firstPos = false;
					}

					ExtinctionAccumulator += baseDensity;
					MaxOpticalDepth += baseDensity * deltaStepLength;

				}

				cloud.pos += deltaStep;
				sampleCounter += 1;
				Depth += deltaStepLength;
				
		}

		if (sampleCounter > 0)
		{
			MeanExtinction = ExtinctionAccumulator / sampleCounter;
		}
	}

	//vec4 lightSpaceWorldPos = m4LightViewProjX * vec4(frontCloudPos, 1.0);
	//float lightSpaceDepth = (lightSpaceWorldPos.z / lightSpaceWorldPos.w);
	

	//float finalDepth = length(frontCloudPos.xyz - v3CameraPosition);

	vec4 LightSpacePos = m4LightViewProjX * vec4(frontCloudPos.xyz, 1.0);
	LightSpacePos /= LightSpacePos.w;

	float tempDepth = LightSpacePos.z ;

	float near = 150000.0 * fShadowFactor;
	float far = near + 150000.0;

	near = 10.0;
	far = near + 10000.0;

	//tempDepth = linearize_depthVulkan(tempDepth, near, far)/ (far- near);

	imageStore(cloudShadowMapImage, fragCoords, vec4(FrontDepth,MeanExtinction, MaxOpticalDepth,1.0));// texture will appear empty but its not... RGBA16F


}