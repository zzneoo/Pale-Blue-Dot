#version 460 core

uniform float fEarthRadius;
uniform float fShadowFactor;

uniform vec2 v2InnerOuterRadius;

#define cld_march_steps_max (400)//256 offline

//float earthRadius = 6371.0;
float sphereInnerRadius = v2InnerOuterRadius.x * fEarthRadius * 0.0031446541;
float sphereOuterRadius = v2InnerOuterRadius.y * fEarthRadius * 0.002;

#define EARTH_RADIUS fEarthRadius
#define SPHERE_INNER_RADIUS (EARTH_RADIUS + sphereInnerRadius)
#define SPHERE_OUTER_RADIUS (SPHERE_INNER_RADIUS + sphereOuterRadius)
#define SPHERE_DELTA float(SPHERE_OUTER_RADIUS - SPHERE_INNER_RADIUS)

vec3 sphereCenter = vec3(0.0, -fEarthRadius, 0.0);

#define STRATUS_GRADIENT vec4(0.0, 0.09, 0.11, 0.15)
#define STRATOCUMULUS_GRADIENT vec4(0.01, 0.2, 0.48, 0.625)
#define CUMULUS_GRADIENT vec4(0.02, 0.1, 0.5, 1.0)

layout(local_size_x = 32, local_size_y = 32, local_size_z = 1) in;

uniform layout(rgba32f, binding = 0) writeonly image2D cloudShadowMapImage;

//sampler2D
uniform sampler2D tSampler2D_WeatherMap;
uniform sampler2D tSampler2D_WeatherMapTilable;
uniform sampler3D tSampler3D_PerlinWorley;

//matrices
uniform mat4 m4LightViewProjX;
uniform mat4 m4InvViewX;
uniform mat4 m4PrevViewX;
uniform mat4 m4InvProjX;
uniform mat4 m4ProjX;
//vectors
uniform vec3 v3CameraPosition;
//int
uniform int iPixelID;

float linearize_depth(float d, float zNear, float zFar)
{
	float z_n = 2.0f * d - 1.0f;
	return 2.0f * zNear * zFar / (zFar + zNear - z_n * (zFar - zNear));
}

float linearize_depthVulkan(float d, float zNear, float zFar)
{
	return zNear * zFar / (zFar + d * (zNear - zFar));
}

struct ray_t
{
	vec3 origin;
	vec3 direction;
	float step;
};

struct volume_sampler_t
{
	vec3 origin; // start of ray
	vec3 pos; // current pos of acccumulation ray
	float height;
	float T; // transmitance
	vec3 C; // color
	float alpha;
	vec3 worldPos;
};

float getHeightFraction(vec3 inPos)
{
	return (length(inPos- sphereCenter) - SPHERE_INNER_RADIUS) / (SPHERE_DELTA);
}

vec2 getUVProjection(vec2 p)
{
	return (p/ SPHERE_INNER_RADIUS)  ;
}
vec2 getUVProjection(vec2 p, float Multiplier)
{
	return ((p / SPHERE_OUTER_RADIUS) * Multiplier) + 0.5;
}

float Remap(float val, float oldMin, float oldMax, float newMin, float newMax)
{
	return newMin + ((val - oldMin) / (oldMax - oldMin)) * (newMax - newMin);
}

vec3 IntersectSphereFromInside(const vec3 pos, const vec3 dir, const float r)
{
	//for infinite cloud Distance
	//sphereCenter.xz = pos.xz;
	//sphereCenter.y = pos.y- EARTH_RADIUS;

	//sphereCenter =  vec3(0.0, -EARTH_RADIUS,0.0);
	//sphereCenter.xz = pos.xz;

	vec3 L = pos - sphereCenter;

	float a = dot(dir, dir);
	float b = 2.0 * dot(dir, L);
	float c = dot(L, L) - (r * r);
	float d = sqrt((b * b) - 4.0 * a * c);

	//float p = -b - d;
	float p2 = -b + d;

	float t = p2/ (2.0 * a);
	t = max(0, t);
	return pos + dir * t;
}

bool IntersectSphereFromOutside(const vec3 pos, const vec3 dir, const float r ,out vec3 p1 , out vec3 p2 ,out float tMin ,out float tMax)
{
	//for infinite cloud Distance
	//sphereCenter.xz = pos.xz;
	//sphereCenter.y = pos.y- EARTH_RADIUS;

	//sphereCenter = vec3(0.0, -EARTH_RADIUS, 0.0);
	//sphereCenter.xz = pos.xz;

	vec3 L = pos - sphereCenter;

	float a = dot(dir, dir);
	float b = 2.0 * dot(dir, L);
	float c = dot(L, L) - (r * r);
	float d = (b * b) - 4.0 * a * c;

	if (d < 0.0)
	{
		return false;
	}

	d = sqrt(d);

	float t1 = -b - d;
	float t2 = -b + d;

	//point 1
	float t = t1 / (2.0 * a);
	t = max(0, t);

	p1 = pos + dir * t;

	//tmin for firstDepth
	tMin = t;

	//point 2
	      t = t2 / (2.0 * a);
	t = max(0, t);

	p2 = pos + dir * t;

	//tMax for firstDepth
	tMax = t;

	return true;
}

float getDensityHeightGradientCloud(float heightFraction, float cloudType)
{
	float stratusFactor = 1.0 - clamp(cloudType * 2.0, 0.0, 1.0);
	float stratoCumulusFactor = 1.0 - abs(cloudType - 0.5) * 2.0;
	float cumulusFactor = clamp(cloudType - 0.5, 0.0, 1.0) * 2.0;

	vec4 baseGradient = stratusFactor * STRATUS_GRADIENT + stratoCumulusFactor * STRATOCUMULUS_GRADIENT + cumulusFactor * CUMULUS_GRADIENT;
	//return Remap(heightFraction, baseGradient.x, baseGradient.y, 0.0, 1.0) * Remap(heightFraction, baseGradient.z, baseGradient.w, 1.0, 0.0);
	return smoothstep(baseGradient.x, baseGradient.y, heightFraction) - smoothstep(baseGradient.z, baseGradient.w, heightFraction);
}

float ZzNeoCloudDensity(vec3 cloudPos, float LOD,bool expensive,float HeightFract)//LOD 0 to 1
{


	vec2 cloudPosUV = getUVProjection(cloudPos.xz) * 10.0 * 0.470;
	vec4 WeatherData = texture(tSampler2D_WeatherMap, (cloudPosUV + 1000.0));

	float HD = clamp(getDensityHeightGradientCloud(HeightFract,  1.0 ), 0, 1);//experimental //1.0 - pow(cutoff+0.0005, 4.0)

	return max(clamp(WeatherData.r* WeatherData.r,0.0,1.0),0)* HD;
}

