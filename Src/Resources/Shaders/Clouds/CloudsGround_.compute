float rand(vec2 co)
{
	return fract(sin(dot(co.xy, vec2(12.9898, 78.233))) * 43758.5453);
}

float rand(float n)
{
	return fract(sin(n) * 43758.5453123);
}

float get_sun_phase(vec3 ray_dir, vec3 sun_dir, float g) {
	float t = acos(dot(ray_dir, sun_dir)) *1;
	float term_a = 1 - g * g;
	float term_b = 1 + g * g;
	float term_c = 2 * g * cos(t);
	float term_d = 4 * PI * pow(term_b - term_c, 3.0 / 2.0);
	float phase = term_a / term_d;
	return phase;
}

vec3 U2ToneMapping(vec3 color)
 {
	const float A = 0.15;
	const float B = 0.50;
	const float C = 0.10;
	const float D = 0.20;
	const float E = 0.02;
	const float F = 0.30;

	color= (((color * (A * color + C * B) + D * E) / (color * (A * color + B) + D * F)) - E / F);
	return color;
 }

vec3 Uncharted2ToneMapping(vec3 color,float Exposure)
{
	float A = 0.15;
	float B = 0.50;
	float C = 0.10;
	float D = 0.20;
	float E = 0.02;
	float F = 0.30;
	float W = 11.2;
	float exposure = Exposure;
	color *= exposure;
	color = ((color * (A * color + C * B) + D * E) / (color * (A * color + B) + D * F)) - E / F;
	float white = ((W * (A * W + C * B) + D * E) / (W * (A * W + B) + D * F)) - E / F;
	color /= white;
	return color;
}

vec3 filmicToneMapping(vec3 color)
{
	color = max(vec3(0.), color - vec3(0.004));
	color = (color * (6.2 * color + .5)) / (color * (6.2 * color + 1.7) + 0.06);
	return color;
}

vec3 SimpleToneMap(vec3 color)
{
	float exposure = 2.5;
	color=1.0 - exp(-color * exposure);
	return color;
}

vec3 simpleReinhardToneMapping(vec3 color)
{

	color *= 1. / (1. + color);
	return color;
}

vec3 lumaBasedReinhardToneMapping(vec3 color)
{
	float luma = dot(color, vec3(0.2126, 0.7152, 0.0722));
	float toneMappedLuma = luma / (1. + luma);
	color *= toneMappedLuma / luma;
	return color;
}

vec3 unreal(vec3 x)
{
	return x / (x + 0.155) * 1.019;
}

float Remap(float val, float oldMin, float oldMax, float newMin, float newMax)
{
	return newMin + ((val - oldMin) / (oldMax - oldMin)) * (newMax - newMin);
}

float Remap_tri(float v)
{
	float original = v * 2.0 - 1.0;
	float z = max(-1.0, original / sqrt(abs(original)));
	return z - sign(original) + 0.5;
}

vec2 getUVProjection(vec2 p,float Multiplier)
{
	return ((p/ SPHERE_OUTER_RADIUS) * Multiplier)+0.5;
}

vec2 getUVProjection_new(vec3 p)
{
	float u = 0.5 + atan(p.x, p.z) / (2 * PI);
	float v = 0.5 - asin(p.y) / PI;
	return vec2(u, v);
}

float getHeightFraction(vec3 inPos)
{
	return (length(inPos- EarthCenter) - SPHERE_INNER_RADIUS) / (SPHERE_DELTA);
}


vec3 IntersectSphereFromInside(const vec3 pos, const vec3 dir, const float r)
{
	//for infinite cloud Distance
	//sphereCenter.xz = pos.xz;
	//sphereCenter.y = pos.y- EARTH_RADIUS;

	//sphereCenter =  vec3(0.0, -EARTH_RADIUS,0.0);
	//sphereCenter.xz = pos.xz;

	vec3 L = pos - EarthCenter;

	float a = dot(dir, dir);
	float b = 2.0 * dot(dir, L);
	float c = dot(L, L) - (r * r);
	float d = sqrt((b * b) - 4.0 * a * c);

	//float p = -b - d;
	float p2 = -b + d;

	float t = p2/ (2.0 * a);
	t = max(0, t);
	return pos + dir * t;
}

vec2 raySphere(vec3 sphereCentre, float sphereRadius, vec3 rayOrigin, vec3 rayDir)
{
	vec3 offset = rayOrigin - sphereCentre;
	float a = 1; // Set to dot(rayDir, rayDir) if rayDir might not be normalized
	float b = 2 * dot(offset, rayDir);
	float c = dot(offset, offset) - sphereRadius * sphereRadius;
	float d = b * b - 4 * a * c; // Discriminant from quadratic formula

	// Number of intersections: 0 when d < 0; 1 when d = 0; 2 when d > 0
	if (d > 0)
	{
		float s = sqrt(d);
		float dstToSphereNear = max(0, (-b - s) / (2 * a));
		float dstToSphereFar = (-b + s) / (2 * a);

		// Ignore intersections that occur behind the ray
		if (dstToSphereFar >= 0)
		{
			return vec2(dstToSphereNear, dstToSphereFar - dstToSphereNear);
		}
	}
	// Ray did not intersect sphere
	 const float maxFloat = 3.402823466e+38;
	return vec2(maxFloat, 0);
}

vec2 rayShellInfo(vec3 rayPos, vec3 rayDir,vec3 sphereCenter)
{
	vec2 innerSphereHitInfo = raySphere(sphereCenter, SPHERE_INNER_RADIUS, rayPos, rayDir);
	vec2 outerSphereHitInfo = raySphere(sphereCenter, SPHERE_OUTER_RADIUS, rayPos, rayDir);
	float dstToInnerSphere = innerSphereHitInfo.x;
	float dstThroughInnerSphere = innerSphereHitInfo.y;
	float dstToOuterSphere = outerSphereHitInfo.x;
	float dstThroughOuterSphere = outerSphereHitInfo.y;
	float dstFromCentre = length(rayPos - sphereCenter);

	float dstToShell = 0;
	float dstThroughShell = 0;

	// View point is from outside the outer shell
	if (dstFromCentre > SPHERE_OUTER_RADIUS)
	{
		dstToShell = dstToOuterSphere;
		dstThroughShell = (dstThroughInnerSphere > 0) ? dstToInnerSphere - dstToOuterSphere : dstThroughOuterSphere;
	}
	// View point is inside the shell
	else if (dstFromCentre > SPHERE_INNER_RADIUS)
	{
		dstToShell = 0;
		dstThroughShell = (dstThroughInnerSphere > 0) ? dstToInnerSphere : dstThroughOuterSphere;
	}
	// View point is inside the inner shell
	else {
		dstToShell = dstThroughInnerSphere;
		dstThroughShell = dstThroughOuterSphere - dstThroughInnerSphere;
	}

	return vec2(dstToShell, dstThroughShell);
}

vec3 IntersectInnerOrOuterAtmosphere(const vec3 pos, const vec3 dir, const float radiusInner, const float radiusOuter)
{

	vec3 L = pos - EarthCenter;

	float a = dot(dir, dir);
	float b = 2.0 * dot(dir, L);
	float c = dot(L, L) - (radiusInner * radiusInner);
	float d = (b * b) - 4.0 * a * c;

	if (d < 0.0)
	{
		return IntersectSphereFromInside(pos, dir, radiusOuter);
	}

	d = sqrt(d);

	float t1 = -b - d;//first from outer
	float t2 = -b + d;//second from outer

	//point 1
	float t = t1 / (2.0 * a);
	t = max(0, t);

	return  pos + dir * t;
}

bool IntersectSphereFromOutside(const vec3 pos, const vec3 dir, const float r ,out vec3 p1 , out vec3 p2)
{
	//for infinite cloud Distance
	//sphereCenter.xz = pos.xz;
	//sphereCenter.y = pos.y- EARTH_RADIUS;

	//sphereCenter = vec3(0.0, -EARTH_RADIUS, 0.0);
	//sphereCenter.xz = pos.xz;

	vec3 L = pos - EarthCenter;

	float a = dot(dir, dir);
	float b = 2.0 * dot(dir, L);
	float c = dot(L, L) - (r * r);
	float d = (b * b) - 4.0 * a * c;

	if (d < 0.0)
	{
		return false;
	}

	d = sqrt(d);

	float t1 = -b - d;
	float t2 = -b + d;

	//point 1
	float t = t1 / (2.0 * a);
	t = max(0, t);

	p1 = pos + dir * t;

	//point 2
	      t = t2 / (2.0 * a);
	t = max(0, t);

	p2 = pos + dir * t;

	return true;
}

vec3 IntersectSphereTest(const vec3 pos, const vec3 dir, const float r)
{
	//for infinite cloud Distance
	//sphereCenter.xz = pos.xz;
	//sphereCenter.y = pos.y- EARTH_RADIUS;

	//sphereCenter = vec3(0.0, -EARTH_RADIUS, 0.0);
	//sphereCenter.xz = pos.xz;

	vec3 L = pos - EarthCenter;

	float a = dot(dir, dir);
	float b = 2.0 * dot(dir, L);
	float c = dot(L, L) - (r * r);
	float d = sqrt((b * b) - 4.0 * a * c);

	float p = -b - d;
	float p2 = -b + d;

	float t = p / (2.0 * a);
	t = max(0, t);
	return pos + dir * t;
}

float HenyeyGreenstein(float toSunDirDotRayDir, float inG)
{
	float g2 = inG * inG;
	//return (1.0 - g2) / (pow(1.0 + g2 - 2.0 * inG * toSunDirDotRayDir, 1.5) * 4.0 * 3.14159265359);
	return (((1.0 - g2) / pow((1.0 + g2 - 2.0 * inG * toSunDirDotRayDir), 1.5)) / 4.0 * 3.14159265359);//3.0/2.0=1.5   and   try removing (/ 4.0 * 3.14159265359)
}

float PowderEffect(float baseDensity, float toSunDirDotRayDir)
{
	float powder = (1.0 - exp(-baseDensity * 2.0)) * 2.0;
	return mix(1.0, powder, clamp(-toSunDirDotRayDir * 0.5 + 0.5, 0.0, 1.0));// Ray z is negative so -dot
}

float getDensityHeightGradientCloud(float heightFraction, float cloudType)
{
	float stratusFactor = 1.0 - clamp(cloudType * 2.0, 0.0, 1.0);
	float stratoCumulusFactor = 1.0 - abs(cloudType - 0.5) * 2.0;
	float cumulusFactor = clamp(cloudType - 0.5, 0.0, 1.0) * 2.0;

	vec4 baseGradient = stratusFactor * STRATUS_GRADIENT + stratoCumulusFactor * STRATOCUMULUS_GRADIENT + cumulusFactor * CUMULUS_GRADIENT;
	//return Remap(heightFraction, baseGradient.x, baseGradient.y, 0.0, 1.0) * Remap(heightFraction, baseGradient.z, baseGradient.w, 1.0, 0.0);
	return smoothstep(baseGradient.x, baseGradient.y, heightFraction) - smoothstep(baseGradient.z, baseGradient.w, pow(heightFraction,0.7));
}

float ZzSilverLine(float SunDotEye,float Eccentricity)
{
//	float Eccentricity = 0.922; //range 0 to 1
	float SilverSpread = 1.0;//range 0 to 1
	float SilverIntensity =1.4;//0.87 

	//float HG = max(0.0, HenyeyGreenstein(SunDotEye, Eccentricity));////
	float HG = max(SilverIntensity * HenyeyGreenstein(SunDotEye, 0.99 - SilverSpread), HenyeyGreenstein(SunDotEye, Eccentricity));////
	return HG;
}

float ZzCloudDensity(vec3 cloudPos, float HeightFract)
{
	vec2 WeatherUV = getUVProjection(cloudPos.xz,16);
	vec2 LowWeatherUV = getUVProjection(cloudPos.xz, 1);
	vec2 WeatherUVSpace = getUVProjection(cloudPos.xz, 8);
	vec2 CloudCoverage = texture(tSampler2D_WeatherMap, WeatherUV - fTime * 0.05).rb;
	float LowCloudCoverage = texture(tSampler2D_WeatherMap,0.394*10.0+ WeatherUVSpace - fTime * 0.025).b;
	float HD = getDensityHeightGradientCloud(HeightFract, 1.0);
	float HD_Variation = getDensityHeightGradientCloud(HeightFract, 0.2);

	float FinalCoverage = CloudCoverage.r* fCloudVolumetricCoverage;
	float baseCloud = FinalCoverage * HD ;//coverage base shape

	vec4 noise = texture(tSampler3D_PerlinWorley, 1.284 * vec3(LowWeatherUV *100.0f, HeightFract * 0.147 * v2InnerOuterRadius.y ));
	vec4 noiseHigh = texture(tSampler3D_Worley32, 7.0* vec3(LowWeatherUV *100.0f, HeightFract * 0.147 * v2InnerOuterRadius.y ));
	float WorleyFBM = dot(noiseHigh.rgb, vec3(0.625, 0.25, 0.125));
	float PerlinWorleyFBM = dot(noise.rgb, vec3(0.625, 0.25, 0.125));

	float FinalNoise = noise.r;

	 baseCloud = Remap(baseCloud, (1.0- FinalNoise)*0.467 , 1.0, (0.0), 1.0);//Low details base shape
	 baseCloud = Remap(baseCloud, (1.0 - WorleyFBM) *0.3, 1.0, (0.0), 1.0);//High details
	 baseCloud *= FinalCoverage;//High details

	 //variation
	 float VariationCoverage = smoothstep(0.35, 1.0, LowCloudCoverage)* fCloudVolumetricCoverage;
	 baseCloud += Remap(HD_Variation* VariationCoverage, (1.0 - noise.a) * 0.3,1.0,0.0,1.0)* VariationCoverage;
//	 baseCloud += pow(LowCloudCoverage,4.0)*(1.0- noise.a) * getDensityHeightGradientCloud(HeightFract+0.2*fCloudFactor, 0.1);//bottom density
//	float Density = mix(noise.a,baseCloud, smoothstep(0.2,0.3, HeightFract)) * pow(HeightFract, 0.9);//space
	float Density = baseCloud * pow(HeightFract, 0.5);//ground

	return Density*0.431;
}

float ZzCloudDensityLow(vec3 cloudPos,float HeightFract)
{
	float HD = getDensityHeightGradientCloud(HeightFract, 1.0);
	vec2 WeatherUV = getUVProjection(cloudPos.xz, 16);
	float CloudCoverage = texture(tSampler2D_WeatherMap, WeatherUV - fTime * 0.1).r;

	float Density = CloudCoverage* HD;

	return 1;
}

