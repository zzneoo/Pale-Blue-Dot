float ZzNeoFinalLight(float HG, float HeightFract, float LightDensity, float lowBaseDensity,float CosTheta,float lightStep)
{
	//beerLambert
	float primaryAttenuation = exp(-LightDensity*18);
	float secondaryAttenuation = (exp(-LightDensity *9) * 0.25);
	float BeerLambert = max(primaryAttenuation, secondaryAttenuation);
//	float BeerLambert = max(Remap(CosTheta,0.7 ,1.0, secondaryAttenuation, secondaryAttenuation*0.25), primaryAttenuation);

	//inScatter
	float DepthProbability = mix(0.05+pow(lowBaseDensity, Remap(HeightFract, 0.0, 1.0, 0.5, 2.0)),1.0, clamp(LightDensity / lightStep, 0, 1));//
//	float DepthProbability = smoothstep(fCloudFactor*0.1,0.3,pow(lowBaseDensity, 0.956));//
//	float DepthProbability = (1.0 - exp(-lowBaseDensity * 2) );//
	float verticalProbability = pow(Remap(HeightFract, 0.0, 0.2, 0.007, 1.0),1.0);
	float inScatterProbability = verticalProbability* DepthProbability;
	//brightness
	float Brightness = 7;
	return Brightness  * BeerLambert* HG* inScatterProbability;//
}

float linearize_depthVulkan(float d, float zNear, float zFar)
{
	return zNear * zFar / (zFar + d * (zNear - zFar));
}

// this is where the magic happens
float SampleVolTexTricubically(sampler3D Noise3D, vec3 tc,float size)
{
	vec3 uvw = tc * size - 0.5;

	vec3 uvwi = floor(uvw);
	vec3 uvwf = uvw - uvwi;

	vec3 mo = uvwf - uvwf * uvwf;

#if 1
	mo = (mo * -0.5 + 1.0) * mo;// use this if it improves quality
#endif

	uvwf = (uvwf - mo) / (1.0 - 2.0 * mo);// map modulator to s-curve

	uvw = uvwi + uvwf + vec3(0.5);

	vec4 v = texture(Noise3D, uvw / size);// replace this with native trilinear lookup

	mo *= fract(uvwi * 0.5) * 4.0 - 1.0;// flip modulator bump on every 2nd interval

	return dot(v, vec4(mo, 1.0));
}

//vec3 GetIrradiance(sampler2D irradiance_texture, float r, float mu_s)
//{
//	vec2 uv = GetIrradianceTextureUvFromRMuS( r, mu_s);
//	return texture(irradiance_texture, uv);
//}

vec3 GetSolarRadiance();
vec3 GetSkyRadiance(vec3 camera, vec3 view_ray, float shadow_length,
	vec3 sun_direction, out vec3 transmittance);
vec3 GetSkyRadianceToPoint(vec3 camera, vec3 point, float shadow_length,
	vec3 sun_direction, out vec3 transmittance);
vec3 GetSunAndSkyIrradiance(
	vec3 p, vec3 normal, vec3 sun_direction, out vec3 sky_irradiance);

void main(void)
{
	
	//uint ID = (gl_LocalInvocationID.y % 4 * gl_WorkGroupSize.x/4 ) + gl_LocalInvocationID.x % 4;
	vec3 startPos, endPos;
	vec2 temporalUV;
	//vec2 jitter = (vec2(rand(fTime), rand(fTime + 2.0)) - 0.5) * 1.0/1920.0;

	ivec2 fragCoords = ivec2(gl_GlobalInvocationID.xy);

	vec3 test = vec3(1.0);

	vec2 pixelOffset;
	pixelOffset.x = iPixelID % 4;
	pixelOffset.y = iPixelID / 4;

	 temporalUV = ((fragCoords *4)+0.5 + pixelOffset);

//	vec2 uvCoords = temporalUV / v2Resolution;//realtime
	vec2 uvCoords = (fragCoords+0.5) / v2Resolution;//offline
	vec3 camPos = v3CameraPosition;

	//camPos = vec3(0.0, 10.0, 0.0);

	vec2 ndcRay = (2.0 * (uvCoords)-1.0);//-1 to 1

	vec4 ray_view = m4InvProjX *  vec4(ndcRay, 1.0, 1.0);
	ray_view = vec4(ray_view.xyz, 0.0);
	//ray_view = vec4(ray_view.xy/ ray_view.z, -1.0, 0.0);

	vec3 worldDir = (m4InvViewX * ray_view).xyz;

	worldDir = normalize(worldDir );

	ray_t ray = { camPos,worldDir,0.0 };

	vec3 toSundir = normalize(v3SunPos);
	float CosTheta = dot(toSundir, normalize(ray.direction));
	float SunTheta = dot(toSundir, normalize(camPos- EarthCenter));
	cutoff = dot(ray.direction, vec3(0.0, 1.0, 0.0));

	float lengthOfCameraPos = length(camPos - EarthCenter);//relative to sphere origin

	bool hit = false;

	if ((lengthOfCameraPos >= SPHERE_OUTER_RADIUS))
	{
		bool hitFirst, hitSecond;
		vec3 p1, p2, q1, q2;

		hitFirst = IntersectSphereFromOutside(ray.origin, ray.direction, SPHERE_OUTER_RADIUS, p1, p2);
		hitSecond = IntersectSphereFromOutside(ray.origin, ray.direction, SPHERE_INNER_RADIUS, q1, q2);

		if (hitFirst == false)
		{
			hit = false;

		}
		else
		{
			startPos = p1;
			endPos = p2;

			if (hitSecond == true)
			{
				endPos = q1;
			}

			hit = true;
		}

	}
	else if (lengthOfCameraPos < (SPHERE_INNER_RADIUS))
	{
		startPos = IntersectSphereFromInside(ray.origin, ray.direction, SPHERE_INNER_RADIUS);
		endPos = IntersectSphereFromInside(ray.origin, ray.direction, SPHERE_OUTER_RADIUS);
		hit = true;
		test = vec3(0.0, 1.0, 0.0);
	}
	else
	{
		startPos = ray.origin + ray.direction * 1.2;
		endPos = ray.origin + ray.direction * 5000;
		// endPos = ray.origin + ray.direction * 10000;
		hit = true;
		test = vec3(1.0, 1.0, 0.0);
	}


	// startPos = startPos + ray.direction * (rand(iFrameID)*2.0-1.0) * fCloudFactor*20.0;
	// startPos = startPos + ray.direction * iPixelID * fCloudFactor*50.0;
	 ///////////////////////////origin///cur pos///Height//T/////C//////Alpha//WorldPos///////////////////////////////////////////
	 volume_sampler_t cloud = { startPos , startPos , 0.0, 0.0 , vec3(0), 0.0, startPos };

	// float HG = ZzSilverLine(CosTheta, 0.6);
	 float HG = HenyeyGreenstein(CosTheta, 0.936);
	 float SilverLine = ZzSilverLine(CosTheta, 0.812);

		cloud.T = 1.0;

	if (hit == true)
	{

		if (cloud.pos.y > -400.0)
		{
			vec3 path = endPos - startPos;
			float len = length(path);
			const uint nSteps = uint(cld_march_steps_max);
			float deltaStepLength = len / nSteps;
			vec3 deltaStep = path / nSteps;
			bool CloudFirst = true;

			////Cloud Detection OPTIMIZATION NO 0
			//for (int i = 0; i < int(nSteps); i++)
			//{

			//	float baseDensity = ZzCloudDensityLow(cloud.pos);
			//	if (baseDensity >0.0)
			//	{
			//		cloud.pos -= deltaStep;

			//		path = endPos - cloud.pos;
			//		len = length(path);
			//		nSteps = cld_march_steps_max;
			//		deltaStepLength = len / nSteps;
			//		deltaStep = path / nSteps;
			//		
			//		break;
			//	}
			//	cloud.pos += deltaStep;
			//}
			float lowCloudTest = 0.0;

			for (uint i = 0; i < (nSteps); i++)
			{
				if (cloud.alpha < 0.95)
				{
					if (lowCloudTest > 0.0)
					{

						cloud.height = clamp(getHeightFraction(cloud.pos), 0.0, 1.0);

						float baseDensity = ZzCloudDensity(cloud.pos, cloud.height);
						float LightDensity = baseDensity;
						float ShadowTrans = 1.0;

						//cloudSelfDarkening
						if (baseDensity > 0.0)
						{

							for (int j = 0; j < 6; j += 1)
							{
								float StepLength = (j + 1) * fEarthRadius * 0.0003048;
								vec3 TempPos = cloud.pos + toSundir * StepLength + (RandomConePoints[int(j)] * (j) * 12.0);//+ (RandomConePoints[int(j)] * (j) * 18.0)
								float TempHeight = clamp(getHeightFraction(TempPos), 0.0, 1.0);
								float TempDensity = ZzCloudDensity(TempPos, TempHeight);

								LightDensity += TempDensity;
							}
						}
						//BSM
						vec4 LightSpacePos = m4LightViewProjX * vec4(cloud.pos, 1.0);
						LightSpacePos /= LightSpacePos.w;
						LightSpacePos.xy = LightSpacePos.xy * 0.5 + 0.5;

						float near = 10.0;
						float far = near + 10000.0;

						float LinearEyeDepth = linearize_depthVulkan(LightSpacePos.z, near, far);
						vec3 BeerShadowMap = texture(tSampler2D_BeerShadowMap, LightSpacePos.xy).rgb;

						float OpticalDepth = min(BeerShadowMap.b, BeerShadowMap.g * max(0.0, LinearEyeDepth - BeerShadowMap.r));
						float CloudTransmittance = exp(-OpticalDepth * 0.151);

						float SigmaScattering = 1.0 + 0.0;//10.0*fCloudFactor
						float SigmaAbsorbtion = 0.908;
						float SigmaExtinction = SigmaScattering + SigmaAbsorbtion;//+ 4 * max(CosTheta, 0.0001)


						float SampleSigmaScattering = SigmaScattering * baseDensity;
						float SampleSigmaExtinction = max(SigmaExtinction * baseDensity, 0.000000001);//divide by zero

						float DeltaTrans = exp(-SampleSigmaExtinction * deltaStepLength);//coneSpreadMultiplier

						vec3 skyIrradiance;
						vec3 sunIrradiance;
						sunIrradiance = GetSunAndSkyIrradiance(cloud.pos - EarthCenter - vec3(0.0, 410.0 * 0.0, 0.0), toSundir, toSundir, skyIrradiance);

						//float BeerLambert = max(exp(-LightDensity * 5), exp(-LightDensity*2));
						float BeerLambert = exp(-LightDensity * 10.85);//space
						float CloudBottom = smoothstep(0.0, 0.3, cloud.height);
						float DarkEdges = mix(pow(baseDensity * 20, 2.0), 1.0, max(CosTheta, 0.0));
						vec3 S = (vec3(sunIrradiance * v3SunColor) * SilverLine * CloudBottom * 0.1 * BeerLambert + skyIrradiance * 0.757*50.0+0.0032) * SampleSigmaScattering;

						//  Sebastien Hilaire (SebH) <3 Improved integration
						vec3 Sint = (S - S * DeltaTrans) / SampleSigmaExtinction;
						cloud.C += cloud.T * Sint;
						cloud.T *= DeltaTrans;

						cloud.worldPos += deltaStep * cloud.T;
						cloud.pos += deltaStep;
					}
					else
					{
						cloud.height = clamp(getHeightFraction(cloud.pos), 0.0, 1.0);
						lowCloudTest = ZzCloudDensityLow(cloud.pos, cloud.height);
						if (lowCloudTest == 0.0)
						{
							cloud.pos += deltaStep * 3;
						}
						else
						{
							cloud.pos -= deltaStep * 2;
						}
					}
					cloud.alpha = 1.0 - cloud.T;//final alpha
				}
			}

			vec3 transmittance;
			vec3 in_scatter = GetSkyRadianceToPoint(v3CameraPosition - EarthCenter, cloud.worldPos - EarthCenter, 0.0, toSundir, transmittance);

			cloud.C = cloud.C * transmittance + in_scatter * smoothstep(0.0, 0.638, 1.0 - exp2(-length(camPos - cloud.worldPos) * 0.0001628));

			imageStore(cloudNearestImage, fragCoords, vec4(pow(unreal(cloud.C * fExposure), vec3(0.454545)), cloud.alpha));
			imageStore(cloudLinearImage, fragCoords, vec4(pow(unreal(cloud.C * fExposure), vec3(0.454545)), cloud.alpha));
			//	imageStore(cloudDepthImage, ivec2(fragCoords), vec4(0.0, 0, 0, 1));
		///////////////////////////////////////////////////////////////////////////////////

			//	imageStore(cloudNearestImage, ivec2(fragCoords), vec4(Uncharted2ToneMapping(cld.rgb, 1.0), cld.a));//SimpleToneMap(cld.rgb)//vec3(cld.a>0?1.0:0.0)
			//	imageStore(cloudLinearImage, ivec2(fragCoords), vec4(Uncharted2ToneMapping(cld.rgb, 1.0), cld.a));//SimpleToneMap(cld.rgb)//vec3(cld.a>0?1.0:0.0)
			//	imageStore(cloudDepthImage, ivec2(fragCoords), vec4(cloudDepth / maxCloudDepth, HighAltitudeCloudAlpha, 0, 1));
		}
		else
		{
			imageStore(cloudNearestImage, fragCoords, vec4(vec3(0.0), 0.0));
			imageStore(cloudLinearImage, fragCoords, vec4(vec3(0.0), 0.0));
		}

	}
	else
	{
		imageStore(cloudNearestImage, fragCoords, vec4(vec3(0.0), 0.0));
		imageStore(cloudLinearImage, fragCoords, vec4(vec3(0.0), 0.0));
	}

	
		//velocity
	vec4 previousPos = m4ProjX * m4PrevViewX * vec4(cloud.worldPos, 1.0);
	previousPos /= previousPos.w;
	vec2 q_cs = previousPos.xy;
	vec2 q_uv = q_cs * 0.5 + 0.5;

	vec2 velocity = uvCoords - q_uv;

	imageStore(cloudVelocityImage, fragCoords, vec4(velocity, 0.0, 1.0));

	if ((endPos.y>-347) && (lengthOfCameraPos< SPHERE_INNER_RADIUS))
	{
		//FarClouds
		vec3 skyIrradiance;
		vec3 sunIrradiance;
		sunIrradiance = GetSunAndSkyIrradiance(endPos - EarthCenter - vec3(0.0, 374.0*2.0, 0.0), toSundir, toSundir, skyIrradiance);
		vec3 transmittance;
		vec3 in_scatter = GetSkyRadianceToPoint(v3CameraPosition - EarthCenter, endPos - EarthCenter, 0.0, toSundir, transmittance);

		float sin_factor = sin(0.839);
		float cos_factor = cos(0.839);
		vec2 FarUV = (endPos.xz * 0.001) *mat2(cos_factor, sin_factor, -sin_factor, cos_factor);

		float FarClouds = texture(tSampler2D_Cirrus, FarUV).r;
		vec3 FarCloudColor = FarClouds * HG * sunIrradiance * 0.05* fCloudVolumetricCoverage;
		FarCloudColor = FarCloudColor * transmittance + in_scatter;

		imageStore(cloudFarImage, fragCoords, vec4(pow(unreal(FarCloudColor * fExposure), vec3(0.454545)), FarClouds));
	}
	else
	{
		imageStore(cloudFarImage, fragCoords, vec4(0.0));
	}

}